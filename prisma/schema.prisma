generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Workspace {
  id          String   @id
  name        String
  description String
  emoji       String
  boards      Board[]
}

model Board {
  id          String       @id
  name        String
  workspaceId String
  background  String
  emoji       String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lists       List[]
  butlerRules ButlerRule[]
}

model List {
  id       String @id
  name     String
  boardId  String
  position Int
  board    Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards    Card[]
}

model Card {
  id          String       @id
  title       String
  description String
  listId      String
  position    Int
  dueDate     String?
  coverColor  String?
  coverImage  String?
  archived    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  list        List         @relation(fields: [listId], references: [id], onDelete: Cascade)
  labels      CardLabel[]
  members     CardMember[]
  checklists  Checklist[]
  comments    Comment[]
  attachments Attachment[]
  activities  Activity[]
}

model CardLabel {
  id     String @id @default(uuid())
  cardId String
  color  String
  text   String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model CardMember {
  id     String @id @default(uuid())
  cardId String
  name   String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model Checklist {
  id     String          @id
  name   String
  cardId String
  card   Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items  ChecklistItem[]
}

model ChecklistItem {
  id          String    @id
  text        String
  completed   Boolean
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id
  author    String
  text      String
  createdAt DateTime @default(now())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model Attachment {
  id     String @id
  name   String
  url    String
  type   String
  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id
  action    String
  timestamp DateTime @default(now())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model ButlerRule {
  id      String  @id
  trigger String
  action  String
  active  Boolean @default(true)
  boardId String
  board   Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
}

model Member {
  id   String @id @default(uuid())
  name String @unique
}
