// Schema matches the current app's data model (see src/lib/boardStore.tsx).
// No auth yet — that's a later step.

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id     String  @id // initials, e.g. "JD"
  name   String
  role   String // Superadmin | Owner | Manager | Member
  color  String
  avatar String? // data URL or remote URL
}

model Board {
  id       String   @id
  name     String
  color    String
  position Int      @default(0)
  columns  Column[]
}

model Column {
  id        String @id
  name      String
  dotBg     String
  dotBorder String
  position  Int    @default(0)
  boardId   String
  board     Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]
}

model Card {
  id          String   @id
  title       String
  due         String?
  progress    Int?
  featured    Boolean  @default(false)
  description String?
  labels      String[]
  members     String[]
  checklist   Json? // [{ id, text, done }]
  comments    Json? // [{ id, author, text, ts }]
  position    Int      @default(0)
  columnId    String
  column      Column   @relation(fields: [columnId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}
